# Токен Telegram-бота (получи у @BotFather)
BOT_TOKEN=your_bot_token_here

# URL Web App (обязательно HTTPS для кнопки в Telegram)
# Для локальной разработки оставь пустым
WEBAPP_URL=https://yourdomain.com/app

# Путь к базе данных
DB_PATH=dice_rolls.db

# Путь к HTML файлу панели Мастера
FRONTEND_PATH=index.html
